# Copia este archivo como .env.local y completa tu clave.
#
# GEMINI_API_KEY — clave de Google AI Studio (gratis): https://aistudio.google.com/apikey
# La usa /api/correo-ai para el "Crear con IA" del editor de correos.
GEMINI_API_KEY=

# Opcional: modelo de Gemini a usar (default: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite
